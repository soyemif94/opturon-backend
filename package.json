{
  "name": "odontology-automation-base",
  "version": "1.0.0",
  "description": "Base automation backend for dental clinics (webhook + AI + storage + auto reply)",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:prod": "cross-env NODE_ENV=production node src/server.js",
    "worker:prod": "cross-env NODE_ENV=production node src/worker.js",
    "prod:up": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/prod-up.ps1",
    "db:migrate": "node src/db/migrate.js",
    "db:sync:wa-channel": "node src/db/sync-whatsapp-channel.js",
    "db:init": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/postgres-init.ps1",
    "db:seed": "node src/db/seed.js",
    "prod:install-tasks": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/install-tasks.ps1",
    "prod:uninstall-tasks": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/uninstall-tasks.ps1",
    "prod:run-now": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/run-now.ps1",
    "prod:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/prod-verify.ps1",
    "prod:verify-debug": "node scripts/verify-debug-routes.cjs",
    "tunnel:route": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/tunnel-route.ps1",
    "tunnel:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup/tunnel-verify-dns.ps1",
    "dev:test:extract": "node scripts/dev-test-extract.js",
    "dev:test:duplicate": "node scripts/dev-test-duplicate.js",
    "dev:test:turno": "node scripts/dev-test-turno-mvp.js",
    "dev:test:appointments": "node scripts/dev-test-appointments-panel.js",
    "dev:test:appointments:db": "node scripts/dev-test-appointments-db.js",
    "dev:test:inbox": "node scripts/dev-test-inbox.js",
    "dev:test:ai:audit": "node scripts/dev-test-ai-audit.js",
    "diag:wa:assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ps/whatsapp_graph_diagnose.ps1",
    "diag:wa:asset-link": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ps/whatsapp_asset_link_diagnose.ps1",
    "diag:wa:phone": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ps/whatsapp_phone_diagnose.ps1",
    "diag:wa:token": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ps/whatsapp_token_diagnose.ps1",
    "diag:wa:waba": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ps/waba_diagnose.ps1",
    "diag:wa:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ps/whatsapp_send_smoke.ps1",
    "worker": "node src/worker.js",
    "test:phase2": "powershell -ExecutionPolicy Bypass -File scripts/tests/phase2-mini-tests.ps1"
  },
  "keywords": [
    "nodejs",
    "express",
    "openai",
    "google-sheets",
    "whatsapp",
    "dental"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "googleapis": "^140.0.1",
    "helmet": "^7.1.0",
    "luxon": "^3.5.0",
    "morgan": "^1.10.0",
    "openai": "^4.56.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.4"
  }
}
